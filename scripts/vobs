#!/usr/bin/env python3

import os
import sys
import subprocess
from pathlib import Path

VAULT = Path.home() / "Documents" / "Obsidian Vault"

def usage():
    print("Usage:")
    print("  vobs                     # open vault")
    print("  vobs <dir>               # open vault/<dir>")
    print("  vobs <dir> <file.md>     # symlink file into vault/<dir>/")
    sys.exit(1)

def open_obsidian(path: Path):
    uri = f"obsidian://open?path={path.resolve()}"
    subprocess.run(["open", uri], check=False)

def main():
    if not VAULT.exists():
        print(f"Vault not found: {VAULT}")
        sys.exit(1)

    args = sys.argv[1:]

    # vobs
    if len(args) == 0:
        open_obsidian(VAULT)
        return

    target_dir = args[0]
    vault_target = VAULT if target_dir == "." else VAULT / target_dir

    # vobs drone
    if len(args) == 1:
        if not vault_target.exists():
            print(f"Vault directory does not exist: {vault_target}")
            sys.exit(1)
        open_obsidian(vault_target)
        return

    # vobs drone esc.md
    if len(args) == 2:
        src = Path(args[1]).expanduser().resolve()

        if not src.exists():
            print(f"Source file does not exist: {src}")
            sys.exit(1)

        vault_target.mkdir(parents=True, exist_ok=True)
        dst = vault_target / src.name

        if dst.exists():
            print(f"File already exists in vault: {dst}")
            sys.exit(1)

        os.symlink(src, dst)
        print(f"Symlinked:\n  {src} → {dst}")
        open_obsidian(dst.parent)
        return

    usage()

if __name__ == "__main__":
    main()
